# Azure OpenAI — SKCC 개발 리소스 예시 (엔드포인트·배포명)
# AOAI_API_KEY 는 Azure 포털에서 복사해 프로젝트 루트 `.env` 에만 넣으세요. 이 파일·Git에는 비밀을 넣지 마세요.
# 참고: docs/env/ai-models.md

AOAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AOAI_API_KEY=PASTE_YOUR_AOAI_KEY_IN_PROJECT_ROOT_DOTENV
AOAI_API_VERSION=2024-08-01-preview

AOAI_DEPLOY_GPT4O_MINI=gpt-4o-mini
AOAI_DEPLOY_GPT4O=gpt-4o
AOAI_DEPLOY_EMBED_3_LARGE=text-embedding-3-large
AOAI_DEPLOY_EMBED_3_SMALL=text-embedding-3-small
AOAI_DEPLOY_EMBED_ADA=text-embedding-ada-002

# mini | gpt4o
AOAI_CHAT_DEPLOY=mini

# Chroma가 AOAI 임베딩을 쓰려면 1 (기존 로컬 임베딩 DB와 호환 안 될 수 있음)
# RAG_USE_AOAI_EMBEDDINGS=1

# OpenAI 공식 API 폴백 (AOAI 미설정 시)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
